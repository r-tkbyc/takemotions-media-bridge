<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Open a localhost server socket -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Keep serving while the screen is off / app backgrounded -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Persistent "running" notification (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Resolve a media app's display name (e.g. "Spotify") from its package, despite
         Android 11+ package-visibility filtering. Restricted on Google Play, but
         Media Bridge is sideloaded (not on Play), so this is fine. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MediaBridge"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service: runs the localhost HTTP server + shows the ongoing notification -->
        <service
            android:name=".BridgeService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Serves the currently-playing media info to TakeMotions glasses companion apps over the loopback interface (127.0.0.1) and relays their playback commands." />
        </service>

        <!-- Empty notification listener. It is ONLY the access handle Android requires for
             MediaSessionManager.getActiveSessions; its callbacks are no-ops. Media Bridge
             never reads, stores, or transmits notification content. -->
        <service
            android:name=".MediaAccessService"
            android:exported="false"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
    </application>

</manifest>
